<script>
// ── DATA ──
const fleet = [
  { icon:'🚗', name:'7 Seater', capacity:'Up to 7 Passengers', features:['AC Equipped','Comfortable Seats','Luggage Space'] },
  { icon:'🚐', name:'12 Seater Hiace', capacity:'Up to 12 Passengers', features:['AC Equipped','Spacious Interior','Airport Ready'] },
  { icon:'🚐', name:'14 Seater Hiace', capacity:'Up to 14 Passengers', features:['AC Equipped','Reclining Seats','USB Charging'] },
  { icon:'🚌', name:'22 Seater Coaster', capacity:'Up to 22 Passengers', features:['AC Equipped','Luggage Hold','Comfortable Ride'] },
  { icon:'🚌', name:'30 Seater Bus', capacity:'Up to 30 Passengers', features:['Full AC','Storage Space','Group Travel'] },
  { icon:'🚌', name:'33 Seater Bus', capacity:'Up to 33 Passengers', features:['Full AC','Reclining Seats','Corporate Ready'] },
  { icon:'🚌', name:'35 Seater Bus', capacity:'Up to 35 Passengers', features:['Full AC','Luggage Storage','WiFi Optional'] },
  { icon:'🚌', name:'50 Seater Bus', capacity:'Up to 50 Passengers', features:['Full AC','Large Luggage Hold','Tour Ready'] },
  { icon:'⭐', name:'Luxury Bus', capacity:'Premium Experience', features:['VIP Interior','Entertainment System','Extra Legroom'] },
  { icon:'🚌', name:'Multiple Vehicles', capacity:'Large Groups & Events', features:['Fleet Coordination','Event Specialist','Corporate Rates'] },
];

const tripTypes = [
  {val:'one-way', icon:'➡️', label:'One Way'},
  {val:'return', icon:'↩️', label:'Return Trip'},
  {val:'daily', icon:'📅', label:'Daily Transport'},
  {val:'monthly', icon:'🗓️', label:'Monthly Contract'},
  {val:'airport', icon:'✈️', label:'Airport Transfer'},
  {val:'city-tour', icon:'🗺️', label:'City Tour'},
  {val:'event', icon:'🎉', label:'Event Transport'},
  {val:'staff', icon:'👷', label:'Staff Transport'},
  {val:'school', icon:'🎓', label:'School Transport'},
];

const budgets = [
  'Less than AED 500',
  'AED 500 – 1,000',
  'AED 1,000 – 3,000',
  'AED 3,000 – 5,000',
  'AED 5,000+',
];

const contactMethods = [
  {val:'call', icon:'📞', label:'Call'},
  {val:'whatsapp', icon:'💬', label:'WhatsApp'},
  {val:'email', icon:'✉️', label:'Email'},
];

const whyCards = [
  {icon:'👨‍✈️', title:'Professional Drivers', desc:'Licensed, experienced, and background-checked drivers familiar with all UAE routes.'},
  {icon:'✨', title:'Clean Vehicles', desc:'All vehicles are regularly sanitized, maintained, and inspected for your safety.'},
  {icon:'💰', title:'Competitive Rates', desc:'Transparent pricing with no hidden fees. Best value for corporate and group travel.'},
  {icon:'✈️', title:'Airport Transfers', desc:'Punctual airport pickups and drop-offs from all UAE international airports.'},
  {icon:'🎓', title:'School Transport', desc:'Safe, reliable, and dedicated school bus services with trained drivers.'},
  {icon:'🏢', title:'Corporate Transport', desc:'Customized staff shuttle services for offices, factories, and business parks.'},
  {icon:'👷', title:'Labour Transport', desc:'Efficient and affordable transportation for labour camps and construction sites.'},
  {icon:'🎉', title:'Event Transportation', desc:'Full fleet coordination for weddings, conferences, tours, and group events.'},
  {icon:'🕐', title:'24/7 Support', desc:'Our team is available round-the-clock to assist with bookings and emergencies.'},
];

// ── RENDER FLEET ──
const fleetGrid = document.querySelector('.fleet-grid');
fleet.forEach((v, i) => {
  const card = document.createElement('label');
  card.className = 'fleet-card';
  card.innerHTML = `
    <input type="radio" name="fleetType" value="${v.name}">
    <div class="fleet-check">✓</div>
    <span class="fleet-icon">${v.icon}</span>
    <div class="fleet-name">${v.name}</div>
    <div class="fleet-capacity">👥 ${v.capacity}</div>
    <ul class="fleet-features">${v.features.map(f=>`<li>${f}</li>`).join('')}</ul>
  `;
  card.addEventListener('click', () => {
    document.querySelectorAll('.fleet-card').forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');
  });
  fleetGrid.appendChild(card);
});

// ── RENDER TRIP TYPES ──
const tripGrid = document.getElementById('tripTypeGrid');
tripTypes.forEach((t,i) => {
  const el = document.createElement('div');
  el.className = 'trip-type-option';
  el.innerHTML = `
    <input type="radio" name="tripType" id="tt${i}" value="${t.val}" ${i===0?'checked':''}>
    <label class="trip-type-label" for="tt${i}">
      <span class="trip-icon">${t.icon}</span> ${t.label}
    </label>
  `;
  tripGrid.appendChild(el);
});

// ── RENDER BUDGETS ──
const budgetGrid = document.getElementById('budgetGrid');
budgets.forEach((b,i) => {
  const el = document.createElement('div');
  el.className = 'budget-option';
  el.innerHTML = `
    <input type="radio" name="budget" id="b${i}" value="${b}" ${i===1?'checked':''}>
    <label class="budget-label" for="b${i}">${b}</label>
  `;
  budgetGrid.appendChild(el);
});

// ── RENDER CONTACT METHODS ──
const cmGrid = document.getElementById('contactMethodGrid');
contactMethods.forEach((c,i) => {
  const el = document.createElement('div');
  el.className = 'contact-method-option';
  el.innerHTML = `
    <input type="radio" name="contactMethod" id="cm${i}" value="${c.val}" ${i===1?'checked':''}>
    <label class="contact-method-label" for="cm${i}">${c.icon} ${c.label}</label>
  `;
  cmGrid.appendChild(el);
});

// ── RENDER WHY CARDS ──
const whyGrid = document.getElementById('whyGrid');
whyCards.forEach(w => {
  const card = document.createElement('div');
  card.className = 'why-card';
  card.innerHTML = `<div class="why-icon">${w.icon}</div><div class="why-title">${w.title}</div><div class="why-desc">${w.desc}</div>`;
  whyGrid.appendChild(card);
});

// ── MIN DATE ──
const today = new Date().toISOString().split('T')[0];
document.getElementById('travelDate').min = today;
document.getElementById('returnDate').min = today;

// ── FORM SUBMIT ──
document.getElementById('bookingForm').addEventListener('submit', function(e) {
  e.preventDefault();
  const required = this.querySelectorAll('[required]');
  let valid = true;
  required.forEach(f => {
    if (!f.value.trim()) {
      f.style.borderColor = '#ef4444';
      f.style.boxShadow = '0 0 0 3px rgba(239,68,68,0.12)';
      valid = false;
      f.addEventListener('input', () => {
        f.style.borderColor = '';
        f.style.boxShadow = '';
      }, { once: true });
    }
  });
  if (!valid) {
    const firstErr = this.querySelector('[required]:placeholder-shown, [required][value=""]');
    if (firstErr) firstErr.scrollIntoView({ behavior:'smooth', block:'center' });
    return;
  }
  this.style.display = 'none';
  const success = document.getElementById('successMessage');
  success.style.display = 'block';
  success.scrollIntoView({ behavior:'smooth', block:'center' });
});

// ── SCROLL REVEAL ──
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
</body>
